---
import type { AsinData } from '@/lib/affiliate';

interface Props {
  asin: AsinData;
}

const { asin } = Astro.props;
---

<div class="grid md:grid-cols-2 gap-4 my-6">
  {asin.pros && asin.pros.length > 0 && (
    <div class="bg-green-50 border border-green-200 rounded-lg p-4">
      <h3 class="font-semibold text-green-800 mb-2">What we like</h3>
      <ul class="list-disc list-inside text-green-900 space-y-1">
        {asin.pros.map((pro) => <li>{pro}</li>)}
      </ul>
    </div>
  )}
  {asin.cons && asin.cons.length > 0 && (
    <div class="bg-red-50 border border-red-200 rounded-lg p-4">
      <h3 class="font-semibold text-red-800 mb-2">What to consider</h3>
      <ul class="list-disc list-inside text-red-900 space-y-1">
        {asin.cons.map((con) => <li>{con}</li>)}
      </ul>
    </div>
  )}
</div>
